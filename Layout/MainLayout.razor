@inherits LayoutComponentBase
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="layout-wrapper @(isDark ? "dark-mode" : "light-mode")">

    <nav class="navbar">
        <a href="/" class="navbar-logo">HASXIFY</a>

        <button class="hamburger @(menuOpen ? "open" : "")" @onclick="ToggleMenu">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <ul class="navbar-links @(menuOpen ? "mobile-open" : "")">

            <li><a href="/" @onclick="CloseMenu">Home</a></li>

            <li class="nav-dropdown">
                <span class="nav-dropdown-toggle" @onclick="() => ToggleDropdown(1)">Find Me ▼</span>
                <ul class="nav-dropdown-menu @(openDropdown == 1 ? "mobile-show" : "")">
                    <li><a href="/instagram" @onclick="CloseMenu"><i class="fab fa-instagram"></i> Instagram</a></li>
                    <li><a href="/youtube" @onclick="CloseMenu"><i class="fab fa-youtube"></i> YouTube</a></li>
                    <li><a href="/linkedin" @onclick="CloseMenu"><i class="fab fa-linkedin"></i> LinkedIn</a></li>
                    <li><a href="/twitter" @onclick="CloseMenu"><i class="fab fa-x-twitter"></i> Twitter / X</a></li>
                    <li><a href="/facebook" @onclick="CloseMenu"><i class="fab fa-facebook"></i> Facebook</a></li>
                    <li><a href="/tiktok" @onclick="CloseMenu"><i class="fab fa-tiktok"></i> TikTok</a></li>
                </ul>
            </li>

            <li class="nav-dropdown">
                <span class="nav-dropdown-toggle" @onclick="() => ToggleDropdown(2)">Services ▼</span>
                <ul class="nav-dropdown-menu @(openDropdown == 2 ? "mobile-show" : "")">
                    <li><a href="/services" @onclick="CloseMenu">⚡ All Services</a></li>
                    <li><a href="/video-production" @onclick="CloseMenu">🎬 Video Production</a></li>
                    <li><a href="/social-media" @onclick="CloseMenu">📱 Social Media</a></li>
                    <li><a href="/brand-identity" @onclick="CloseMenu">🎨 Brand Identity</a></li>
                    <li><a href="/content-strategy" @onclick="CloseMenu">📊 Content Strategy</a></li>
                </ul>
            </li>

            <li class="nav-dropdown">
                <span class="nav-dropdown-toggle" @onclick="() => ToggleDropdown(3)">Courses ▼</span>
                <ul class="nav-dropdown-menu @(openDropdown == 3 ? "mobile-show" : "")">
                    <li><a href="/courses" @onclick="CloseMenu">📚 All Courses</a></li>
                    <li><a href="/course-content-creation" @onclick="CloseMenu">🚀 Content Creation</a></li>
                    <li><a href="/course-social-media-growth" @onclick="CloseMenu">📈 Social Media Growth</a></li>
                    <li><a href="/course-personal-branding" @onclick="CloseMenu">💡 Personal Branding</a></li>
                    <li><a href="/course-video-editing" @onclick="CloseMenu">🎬 Video Editing Pro</a></li>
                    <li><a href="/course-monetization" @onclick="CloseMenu">💰 Monetization Secrets</a></li>
                    <li><a href="/course-starter-kit" @onclick="CloseMenu">🎯 Creator Starter Kit</a></li>
                </ul>
            </li>

            <li><a href="/contact" @onclick="CloseMenu">Contact</a></li>
            <li><a href="/login" @onclick="CloseMenu">🎓 Portal</a></li>
            <li><a href="/admin-hasxify-2025" @onclick="CloseMenu">⚙️ Admin</a></li>

        </ul>

        <button class="theme-toggle" @onclick="ToggleTheme" title="Toggle theme">
            @(isDark ? "☀️" : "🌙")
        </button>
    </nav>

    <main>
        @Body
    </main>

    <footer class="footer">
        <div class="footer-logo">HASXIFY</div>
        <p class="footer-text">© 2025 HASXIFY. Crafting content that hits different.</p>
    </footer>

</div>

@code {
    private bool isDark = true;
    private bool menuOpen = false;
    private int openDropdown = 0;
    private DotNetObjectReference<MainLayout>? objRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            isDark = await JS.InvokeAsync<bool>("detectDarkMode", objRef);
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void SetDarkMode(bool dark)
    {
        isDark = dark;
        StateHasChanged();
    }

    private void ToggleMenu()
    {
        menuOpen = !menuOpen;
        if (!menuOpen) openDropdown = 0;
        StateHasChanged();
    }

    private void CloseMenu()
    {
        menuOpen = false;
        openDropdown = 0;
        StateHasChanged();
    }

    private void ToggleDropdown(int id)
    {
        openDropdown = openDropdown == id ? 0 : id;
        StateHasChanged();
    }

    private async Task ToggleTheme()
    {
        isDark = !isDark;
        await JS.InvokeVoidAsync("saveThemePreference", isDark);
    }

    public async ValueTask DisposeAsync()
    {
        objRef?.Dispose();
        await JS.InvokeVoidAsync("removeThemeListener");
    }
}