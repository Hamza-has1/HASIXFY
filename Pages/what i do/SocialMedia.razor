@page "/social-media"
@layout MainLayout

<div class="page-enter">
    <section class="service-hero" style="background: radial-gradient(ellipse at center, rgba(168,85,247,0.2) 0%, transparent 70%), #000;">
        <div class="service-hero-content">
            <span class="service-hero-icon">📱</span>
            <h1 class="platform-title" style="background: linear-gradient(135deg, #fff, #a855f7); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">Social Media Management</h1>
            <p class="platform-sub">Growing your presence across all platforms — consistently</p>
            <a href="/contact" class="btn-primary">Get Started →</a>
        </div>
    </section>

    <section class="services-section">
        <h2 class="section-title">What's Included</h2>
        <p class="section-subtitle">Complete social media management</p>
        <div class="services-grid">
            <div class="service-card reveal">
                <span class="service-icon">📅</span>
                <div class="service-title">Content Calendar</div>
                <p class="service-desc">Monthly content calendars planned in advance so you never miss a posting day.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">✍️</span>
                <div class="service-title">Content Creation</div>
                <p class="service-desc">High-quality posts, reels, stories, and captions created for your brand.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">📊</span>
                <div class="service-title">Analytics & Reports</div>
                <p class="service-desc">Monthly detailed reports on growth, engagement, reach, and performance.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">💬</span>
                <div class="service-title">Community Management</div>
                <p class="service-desc">Responding to comments, DMs, and engaging with your audience daily.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">🎯</span>
                <div class="service-title">Growth Strategy</div>
                <p class="service-desc">Data-driven strategies to grow your following organically and consistently.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">🤝</span>
                <div class="service-title">Influencer Outreach</div>
                <p class="service-desc">Connecting with relevant influencers and brands for collaborations.</p>
            </div>
        </div>
    </section>

    <section class="sp-packages-section">
        <h2 class="section-title">Monthly Packages</h2>
        <p class="section-subtitle">Flexible plans for every budget</p>
        <div class="packages-grid">
            <div class="package-card reveal">
                <div class="package-header" style="background: linear-gradient(135deg, #1a0533, #4c1d95);">
                    <div class="package-name">Basic</div>
                    <div class="package-price">PKR 20,000</div>
                    <div class="package-per">per month</div>
                </div>
                <div class="package-body">
                    <div class="package-feature">✅ 2 platforms</div>
                    <div class="package-feature">✅ 12 posts/month</div>
                    <div class="package-feature">✅ Basic analytics</div>
                    <div class="package-feature">❌ Community management</div>
                    <div class="package-feature">❌ Influencer outreach</div>
                </div>
                <a href="/contact" class="btn-outline" style="display:block; text-align:center; margin:20px;">Get Started</a>
            </div>
            <div class="package-card reveal" style="border-color: rgba(124,58,237,0.6); transform: scale(1.05);">
                <div class="package-header" style="background: linear-gradient(135deg, #4c1d95, #7c3aed);">
                    <div class="package-badge">Most Popular</div>
                    <div class="package-name">Growth</div>
                    <div class="package-price">PKR 45,000</div>
                    <div class="package-per">per month</div>
                </div>
                <div class="package-body">
                    <div class="package-feature">✅ 4 platforms</div>
                    <div class="package-feature">✅ 24 posts/month</div>
                    <div class="package-feature">✅ Full analytics</div>
                    <div class="package-feature">✅ Community management</div>
                    <div class="package-feature">❌ Influencer outreach</div>
                </div>
                <a href="/contact" class="btn-primary" style="display:block; text-align:center; margin:20px;">Get Started</a>
            </div>
            <div class="package-card reveal">
                <div class="package-header" style="background: linear-gradient(135deg, #1e3a8a, #3b82f6);">
                    <div class="package-name">Premium</div>
                    <div class="package-price">PKR 80,000</div>
                    <div class="package-per">per month</div>
                </div>
                <div class="package-body">
                    <div class="package-feature">✅ All platforms</div>
                    <div class="package-feature">✅ Unlimited posts</div>
                    <div class="package-feature">✅ Full analytics</div>
                    <div class="package-feature">✅ Community management</div>
                    <div class="package-feature">✅ Influencer outreach</div>
                </div>
                <a href="/contact" class="btn-outline" style="display:block; text-align:center; margin:20px;">Contact Us</a>
            </div>
        </div>
    </section>
</div>