@page "/video-production"
@layout MainLayout

<div class="page-enter">
    <section class="service-hero" style="background: radial-gradient(ellipse at center, rgba(124,58,237,0.2) 0%, transparent 70%), #000;">
        <div class="service-hero-content">
            <span class="service-hero-icon">🎬</span>
            <h1 class="platform-title" style="background: linear-gradient(135deg, #fff, #c084fc); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">Video Production</h1>
            <p class="platform-sub">Professional videos that captivate, convert & go viral</p>
            <a href="/contact" class="btn-primary">Book a Session →</a>
        </div>
    </section>

    <section class="services-section">
        <h2 class="section-title">What's Included</h2>
        <p class="section-subtitle">End-to-end video production services</p>
        <div class="services-grid">
            <div class="service-card reveal">
                <span class="service-icon">📝</span>
                <div class="service-title">Script Writing</div>
                <p class="service-desc">Professional scripts crafted to engage your audience from the first second to the last.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">🎥</span>
                <div class="service-title">Filming & Direction</div>
                <p class="service-desc">High-quality filming with professional direction to bring your vision to life.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">✂️</span>
                <div class="service-title">Video Editing</div>
                <p class="service-desc">Professional editing with color grading, transitions, and effects that make your content stand out.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">🎵</span>
                <div class="service-title">Sound Design</div>
                <p class="service-desc">Background music, sound effects, and audio mixing for the perfect viewing experience.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">📱</span>
                <div class="service-title">Multi-Platform Export</div>
                <p class="service-desc">Optimized versions for YouTube, Instagram Reels, TikTok, and all major platforms.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">🚀</span>
                <div class="service-title">Upload & Optimization</div>
                <p class="service-desc">SEO-optimized titles, descriptions, tags, and thumbnails for maximum reach.</p>
            </div>
        </div>
    </section>

    <section class="sp-process-section">
        <h2 class="section-title">How It Works</h2>
        <p class="section-subtitle">Simple 4-step process</p>
        <div class="process-grid">
            <div class="process-step reveal">
                <div class="process-num">01</div>
                <div class="process-title">Brief & Planning</div>
                <p class="process-desc">We discuss your goals, target audience, and video concept in detail.</p>
            </div>
            <div class="process-step reveal">
                <div class="process-num">02</div>
                <div class="process-title">Production</div>
                <p class="process-desc">Script writing, filming, and recording with professional equipment.</p>
            </div>
            <div class="process-step reveal">
                <div class="process-num">03</div>
                <div class="process-title">Post Production</div>
                <p class="process-desc">Editing, color grading, sound design, and final touches.</p>
            </div>
            <div class="process-step reveal">
                <div class="process-num">04</div>
                <div class="process-title">Delivery</div>
                <p class="process-desc">Final video delivered in all required formats, ready to publish.</p>
            </div>
        </div>
    </section>

    <section class="sp-packages-section">
        <h2 class="section-title">Packages</h2>
        <p class="section-subtitle">Choose the right package for you</p>
        <div class="packages-grid">
            <div class="package-card reveal">
                <div class="package-header" style="background: linear-gradient(135deg, #1a0533, #4c1d95);">
                    <div class="package-name">Starter</div>
                    <div class="package-price">PKR 15,000</div>
                    <div class="package-per">per video</div>
                </div>
                <div class="package-body">
                    <div class="package-feature">✅ Up to 5 min video</div>
                    <div class="package-feature">✅ Basic editing</div>
                    <div class="package-feature">✅ 1 revision</div>
                    <div class="package-feature">✅ YouTube & Reels format</div>
                    <div class="package-feature">❌ Thumbnail design</div>
                </div>
                <a href="/contact" class="btn-outline" style="display:block; text-align:center; margin:20px;">Get Started</a>
            </div>
            <div class="package-card reveal" style="border-color: rgba(124,58,237,0.6); transform: scale(1.05);">
                <div class="package-header" style="background: linear-gradient(135deg, #4c1d95, #7c3aed);">
                    <div class="package-badge">Most Popular</div>
                    <div class="package-name">Pro</div>
                    <div class="package-price">PKR 35,000</div>
                    <div class="package-per">per video</div>
                </div>
                <div class="package-body">
                    <div class="package-feature">✅ Up to 15 min video</div>
                    <div class="package-feature">✅ Advanced editing</div>
                    <div class="package-feature">✅ 3 revisions</div>
                    <div class="package-feature">✅ All platform formats</div>
                    <div class="package-feature">✅ Thumbnail design</div>
                </div>
                <a href="/contact" class="btn-primary" style="display:block; text-align:center; margin:20px;">Get Started</a>
            </div>
            <div class="package-card reveal">
                <div class="package-header" style="background: linear-gradient(135deg, #1e3a8a, #3b82f6);">
                    <div class="package-name">Enterprise</div>
                    <div class="package-price">Custom</div>
                    <div class="package-per">contact for pricing</div>
                </div>
                <div class="package-body">
                    <div class="package-feature">✅ Unlimited length</div>
                    <div class="package-feature">✅ Premium editing</div>
                    <div class="package-feature">✅ Unlimited revisions</div>
                    <div class="package-feature">✅ All platform formats</div>
                    <div class="package-feature">✅ Full SEO optimization</div>
                </div>
                <a href="/contact" class="btn-outline" style="display:block; text-align:center; margin:20px;">Contact Us</a>
            </div>
        </div>
    </section>
</div>