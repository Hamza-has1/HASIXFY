@page "/content-strategy"
@layout MainLayout

<div class="page-enter">
    <section class="service-hero" style="background: radial-gradient(ellipse at center, rgba(59,130,246,0.2) 0%, transparent 70%), #000;">
        <div class="service-hero-content">
            <span class="service-hero-icon">📊</span>
            <h1 class="platform-title" style="background: linear-gradient(135deg, #fff, #60a5fa); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">Content Strategy</h1>
            <p class="platform-sub">Data-driven strategies that grow your audience and convert followers into fans</p>
            <a href="/contact" class="btn-primary">Get Your Strategy →</a>
        </div>
    </section>

    <section class="services-section">
        <h2 class="section-title">What's Included</h2>
        <p class="section-subtitle">Complete content strategy services</p>
        <div class="services-grid">
            <div class="service-card reveal">
                <span class="service-icon">🔍</span>
                <div class="service-title">Audience Research</div>
                <p class="service-desc">Deep research into your target audience, their behavior, interests, and pain points.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">🏆</span>
                <div class="service-title">Competitor Analysis</div>
                <p class="service-desc">Analyzing top competitors to find gaps and opportunities in your niche.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">📅</span>
                <div class="service-title">Content Roadmap</div>
                <p class="service-desc">3-6 month content roadmap with topics, formats, and publishing schedule.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">📈</span>
                <div class="service-title">Growth Plan</div>
                <p class="service-desc">Step-by-step growth plan with KPIs, milestones, and actionable tactics.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">🔑</span>
                <div class="service-title">SEO & Hashtag Strategy</div>
                <p class="service-desc">Keyword research and hashtag strategy to maximize organic reach and discoverability.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">💡</span>
                <div class="service-title">Monthly Consulting</div>
                <p class="service-desc">Monthly strategy calls to review performance and adjust the plan accordingly.</p>
            </div>
        </div>
    </section>

    <section class="sp-process-section">
        <h2 class="section-title">Our Process</h2>
        <p class="section-subtitle">How we build your winning strategy</p>
        <div class="process-grid">
            <div class="process-step reveal">
                <div class="process-num">01</div>
                <div class="process-title">Discovery Call</div>
                <p class="process-desc">Understanding your brand, goals, current situation, and target audience.</p>
            </div>
            <div class="process-step reveal">
                <div class="process-num">02</div>
                <div class="process-title">Research & Analysis</div>
                <p class="process-desc">Deep dive into your niche, competitors, and audience behavior.</p>
            </div>
            <div class="process-step reveal">
                <div class="process-num">03</div>
                <div class="process-title">Strategy Building</div>
                <p class="process-desc">Creating a custom content strategy tailored specifically to your goals.</p>
            </div>
            <div class="process-step reveal">
                <div class="process-num">04</div>
                <div class="process-title">Implementation</div>
                <p class="process-desc">Executing the strategy with regular monitoring and optimization.</p>
            </div>
        </div>
    </section>

    <section class="sp-packages-section">
        <h2 class="section-title">Packages</h2>
        <p class="section-subtitle">Strategy packages for every stage</p>
        <div class="packages-grid">
            <div class="package-card reveal">
                <div class="package-header" style="background: linear-gradient(135deg, #1a0533, #4c1d95);">
                    <div class="package-name">Basic</div>
                    <div class="package-price">PKR 18,000</div>
                    <div class="package-per">one time</div>
                </div>
                <div class="package-body">
                    <div class="package-feature">✅ Audience research</div>
                    <div class="package-feature">✅ 1 month roadmap</div>
                    <div class="package-feature">✅ Basic SEO strategy</div>
                    <div class="package-feature">❌ Competitor analysis</div>
                    <div class="package-feature">❌ Monthly consulting</div>
                </div>
                <a href="/contact" class="btn-outline" style="display:block; text-align:center; margin:20px;">Get Started</a>
            </div>
            <div class="package-card reveal" style="border-color: rgba(124,58,237,0.6); transform: scale(1.05);">
                <div class="package-header" style="background: linear-gradient(135deg, #4c1d95, #7c3aed);">
                    <div class="package-badge">Most Popular</div>
                    <div class="package-name">Pro</div>
                    <div class="package-price">PKR 40,000</div>
                    <div class="package-per">per month</div>
                </div>
                <div class="package-body">
                    <div class="package-feature">✅ Full audience research</div>
                    <div class="package-feature">✅ 3 month roadmap</div>
                    <div class="package-feature">✅ Full SEO strategy</div>
                    <div class="package-feature">✅ Competitor analysis</div>
                    <div class="package-feature">❌ Monthly consulting</div>
                </div>
                <a href="/contact" class="btn-primary" style="display:block; text-align:center; margin:20px;">Get Started</a>
            </div>
            <div class="package-card reveal">
                <div class="package-header" style="background: linear-gradient(135deg, #1e3a8a, #3b82f6);">
                    <div class="package-name">Elite</div>
                    <div class="package-price">PKR 75,000</div>
                    <div class="package-per">per month</div>
                </div>
                <div class="package-body">
                    <div class="package-feature">✅ Full audience research</div>
                    <div class="package-feature">✅ 6 month roadmap</div>
                    <div class="package-feature">✅ Full SEO strategy</div>
                    <div class="package-feature">✅ Competitor analysis</div>
                    <div class="package-feature">✅ Monthly consulting</div>
                </div>
                <a href="/contact" class="btn-outline" style="display:block; text-align:center; margin:20px;">Contact Us</a>
            </div>
        </div>
    </section>
</div>