@page "/brand-identity"
@layout MainLayout

<div class="page-enter">
    <section class="service-hero" style="background: radial-gradient(ellipse at center, rgba(192,132,252,0.2) 0%, transparent 70%), #000;">
        <div class="service-hero-content">
            <span class="service-hero-icon">🎨</span>
            <h1 class="platform-title" style="background: linear-gradient(135deg, #fff, #c084fc); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">Brand Identity</h1>
            <p class="platform-sub">Building a visual identity that makes you unforgettable</p>
            <a href="/contact" class="btn-primary">Start Your Brand →</a>
        </div>
    </section>

    <section class="services-section">
        <h2 class="section-title">What's Included</h2>
        <p class="section-subtitle">Complete brand identity package</p>
        <div class="services-grid">
            <div class="service-card reveal">
                <span class="service-icon">✏️</span>
                <div class="service-title">Logo Design</div>
                <p class="service-desc">Unique, memorable logos that represent your brand perfectly across all platforms.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">🎨</span>
                <div class="service-title">Color Palette</div>
                <p class="service-desc">Strategic color selection that evokes the right emotions and stands out in your niche.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">🔤</span>
                <div class="service-title">Typography</div>
                <p class="service-desc">Font selection and hierarchy that enhances readability and brand personality.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">📖</span>
                <div class="service-title">Brand Guidelines</div>
                <p class="service-desc">Complete brand style guide so your brand stays consistent everywhere.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">📱</span>
                <div class="service-title">Social Media Kit</div>
                <p class="service-desc">Profile pictures, banners, post templates for all social media platforms.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">📄</span>
                <div class="service-title">Business Materials</div>
                <p class="service-desc">Business cards, letterheads, and other branded materials.</p>
            </div>
        </div>
    </section>

    <section class="sp-packages-section">
        <h2 class="section-title">Packages</h2>
        <p class="section-subtitle">Build your brand the right way</p>
        <div class="packages-grid">
            <div class="package-card reveal">
                <div class="package-header" style="background: linear-gradient(135deg, #1a0533, #4c1d95);">
                    <div class="package-name">Starter</div>
                    <div class="package-price">PKR 25,000</div>
                    <div class="package-per">one time</div>
                </div>
                <div class="package-body">
                    <div class="package-feature">✅ Logo design</div>
                    <div class="package-feature">✅ Color palette</div>
                    <div class="package-feature">✅ Basic guidelines</div>
                    <div class="package-feature">❌ Social media kit</div>
                    <div class="package-feature">❌ Business materials</div>
                </div>
                <a href="/contact" class="btn-outline" style="display:block; text-align:center; margin:20px;">Get Started</a>
            </div>
            <div class="package-card reveal" style="border-color: rgba(124,58,237,0.6); transform: scale(1.05);">
                <div class="package-header" style="background: linear-gradient(135deg, #4c1d95, #7c3aed);">
                    <div class="package-badge">Most Popular</div>
                    <div class="package-name">Complete</div>
                    <div class="package-price">PKR 55,000</div>
                    <div class="package-per">one time</div>
                </div>
                <div class="package-body">
                    <div class="package-feature">✅ Logo design</div>
                    <div class="package-feature">✅ Full color system</div>
                    <div class="package-feature">✅ Complete guidelines</div>
                    <div class="package-feature">✅ Social media kit</div>
                    <div class="package-feature">❌ Business materials</div>
                </div>
                <a href="/contact" class="btn-primary" style="display:block; text-align:center; margin:20px;">Get Started</a>
            </div>
            <div class="package-card reveal">
                <div class="package-header" style="background: linear-gradient(135deg, #1e3a8a, #3b82f6);">
                    <div class="package-name">Premium</div>
                    <div class="package-price">PKR 90,000</div>
                    <div class="package-per">one time</div>
                </div>
                <div class="package-body">
                    <div class="package-feature">✅ Logo design</div>
                    <div class="package-feature">✅ Full color system</div>
                    <div class="package-feature">✅ Complete guidelines</div>
                    <div class="package-feature">✅ Social media kit</div>
                    <div class="package-feature">✅ Business materials</div>
                </div>
                <a href="/contact" class="btn-outline" style="display:block; text-align:center; margin:20px;">Contact Us</a>
            </div>
        </div>
    </section>
</div>