@page "/"
@layout MainLayout
@inject SiteDataService SiteData
@implements IDisposable

<div class="page-enter">

    <section class="hero">
        <div class="hero-orb hero-orb-1"></div>
        <div class="hero-orb hero-orb-2"></div>
        <div class="hero-orb hero-orb-3"></div>
        <div class="hero-inner">
            <div class="hero-content">
                <span class="hero-badge">@SiteData.HeroBadge</span>
                <h1 class="hero-name">@SiteData.HeroName</h1>
                <p class="hero-title">@SiteData.HeroTitle</p>
                <p class="hero-description">@SiteData.HeroDesc</p>
                <div class="hero-buttons">
                    <a href="/services" class="btn-primary">My Services</a>
                    <a href="/contact" class="btn-outline">Let's Connect</a>
                </div>
            </div>
            <div class="hero-photo">
                <div class="hero-photo-ring"></div>
                <img src="mypic.png" alt="HASXIFY" class="hero-img" />
            </div>
        </div>
    </section>

    <!-- FIND ME ONLINE -->
    <section class="social-section">
        <h2 class="section-title">Find Me Online</h2>
        <p class="section-subtitle">Join the community across all platforms</p>
        <div class="social-grid">

            <a href="/instagram" class="social-card card-instagram reveal">
                <span class="social-arrow">↗</span>
                <i class="fab fa-instagram social-icon" style="color:#e1306c; font-size:2.8rem; display:block; margin-bottom:16px; transition:transform 0.3s;"></i>
                <div class="social-name">Instagram</div>
                <div class="social-handle">@SiteData.SocialMedia[0].Handle</div>
                <div class="social-stats">
                    <div class="stat"><div class="stat-number">@SiteData.SocialMedia[0].Followers</div><div class="stat-label">Followers</div></div>
                    <div class="stat"><div class="stat-number">@SiteData.SocialMedia[0].Posts</div><div class="stat-label">Posts</div></div>
                </div>
            </a>

            <a href="/linkedin" class="social-card card-linkedin reveal">
                <span class="social-arrow">↗</span>
                <i class="fab fa-linkedin social-icon" style="color:#0077b5; font-size:2.8rem; display:block; margin-bottom:16px; transition:transform 0.3s;"></i>
                <div class="social-name">LinkedIn</div>
                <div class="social-handle">@SiteData.SocialMedia[1].Handle</div>
                <div class="social-stats">
                    <div class="stat"><div class="stat-number">@SiteData.SocialMedia[1].Followers</div><div class="stat-label">Connections</div></div>
                    <div class="stat"><div class="stat-number">@SiteData.SocialMedia[1].Posts</div><div class="stat-label">Articles</div></div>
                </div>
            </a>

            <a href="/youtube" class="social-card card-youtube reveal">
                <span class="social-arrow">↗</span>
                <i class="fab fa-youtube social-icon" style="color:#ff0000; font-size:2.8rem; display:block; margin-bottom:16px; transition:transform 0.3s;"></i>
                <div class="social-name">YouTube</div>
                <div class="social-handle">@SiteData.SocialMedia[2].Handle</div>
                <div class="social-stats">
                    <div class="stat"><div class="stat-number">@SiteData.SocialMedia[2].Followers</div><div class="stat-label">Subscribers</div></div>
                    <div class="stat"><div class="stat-number">@SiteData.SocialMedia[2].Posts</div><div class="stat-label">Videos</div></div>
                </div>
            </a>

            <a href="/twitter" class="social-card card-twitter reveal">
                <span class="social-arrow">↗</span>
                <i class="fab fa-x-twitter social-icon" style="color:#1da1f2; font-size:2.8rem; display:block; margin-bottom:16px; transition:transform 0.3s;"></i>
                <div class="social-name">Twitter / X</div>
                <div class="social-handle">@SiteData.SocialMedia[3].Handle</div>
                <div class="social-stats">
                    <div class="stat"><div class="stat-number">@SiteData.SocialMedia[3].Followers</div><div class="stat-label">Followers</div></div>
                    <div class="stat"><div class="stat-number">@SiteData.SocialMedia[3].Posts</div><div class="stat-label">Tweets</div></div>
                </div>
            </a>

            <a href="/facebook" class="social-card card-facebook reveal">
                <span class="social-arrow">↗</span>
                <i class="fab fa-facebook social-icon" style="color:#1877f2; font-size:2.8rem; display:block; margin-bottom:16px; transition:transform 0.3s;"></i>
                <div class="social-name">Facebook</div>
                <div class="social-handle">@SiteData.SocialMedia[4].Handle</div>
                <div class="social-stats">
                    <div class="stat"><div class="stat-number">@SiteData.SocialMedia[4].Followers</div><div class="stat-label">Likes</div></div>
                    <div class="stat"><div class="stat-number">@SiteData.SocialMedia[4].Posts</div><div class="stat-label">Posts</div></div>
                </div>
            </a>

            <a href="/tiktok" class="social-card card-tiktok reveal">
                <span class="social-arrow">↗</span>
                <i class="fab fa-tiktok social-icon" style="color:#00f2ea; font-size:2.8rem; display:block; margin-bottom:16px; transition:transform 0.3s;"></i>
                <div class="social-name">TikTok</div>
                <div class="social-handle">@SiteData.SocialMedia[5].Handle</div>
                <div class="social-stats">
                    <div class="stat"><div class="stat-number">@SiteData.SocialMedia[5].Followers</div><div class="stat-label">Followers</div></div>
                    <div class="stat"><div class="stat-number">@SiteData.SocialMedia[5].Posts</div><div class="stat-label">Likes</div></div>
                </div>
            </a>

        </div>
    </section>

    <!-- SERVICES -->
    <section class="services-section">
        <h2 class="section-title">What I Do</h2>
        <p class="section-subtitle">Services designed to elevate your digital presence</p>
        <div class="services-grid">

            <a href="/video-production" class="service-card reveal" style="text-decoration:none; color:inherit; display:block; cursor:pointer;">
                <span class="service-icon">🎬</span>
                <div class="service-title">Video Production</div>
                <p class="service-desc">Professional video content for YouTube, Reels, TikTok and all major platforms.</p>
                <div style="color:#a855f7; margin-top:16px; font-weight:700; font-size:0.9rem;">Learn More →</div>
            </a>

            <a href="/social-media" class="service-card reveal" style="text-decoration:none; color:inherit; display:block; cursor:pointer;">
                <span class="service-icon">📱</span>
                <div class="service-title">Social Media Management</div>
                <p class="service-desc">Full management of your social media presence.</p>
                <div style="color:#a855f7; margin-top:16px; font-weight:700; font-size:0.9rem;">Learn More →</div>
            </a>

            <a href="/brand-identity" class="service-card reveal" style="text-decoration:none; color:inherit; display:block; cursor:pointer;">
                <span class="service-icon">🎨</span>
                <div class="service-title">Brand Identity</div>
                <p class="service-desc">Building a visual identity that makes you unforgettable.</p>
                <div style="color:#a855f7; margin-top:16px; font-weight:700; font-size:0.9rem;">Learn More →</div>
            </a>

            <a href="/content-strategy" class="service-card reveal" style="text-decoration:none; color:inherit; display:block; cursor:pointer;">
                <span class="service-icon">📊</span>
                <div class="service-title">Content Strategy</div>
                <p class="service-desc">Data-driven content plans that grow your audience.</p>
                <div style="color:#a855f7; margin-top:16px; font-weight:700; font-size:0.9rem;">Learn More →</div>
            </a>

        </div>
    </section>

    <!-- COURSES -->
    <section class="courses-section">
        <h2 class="section-title">My Courses</h2>
        <p class="section-subtitle">Learn what actually works in the digital world</p>
        <div class="courses-grid">

            <a href="/course-content-creation" class="course-card reveal" style="text-decoration:none; color:inherit; display:block;">
                <div class="course-banner course-banner-1">🚀</div>
                <div class="course-body">
                    <span class="course-tag">Bestseller</span>
                    <div class="course-title">Content Creation Masterclass</div>
                    <p class="course-desc">Everything you need to go from zero to viral.</p>
                    <div class="course-footer">
                        <span class="course-price">PKR 4,999</span>
                        <span class="course-btn">Enroll Now</span>
                    </div>
                </div>
            </a>

            <a href="/course-social-media-growth" class="course-card reveal" style="text-decoration:none; color:inherit; display:block;">
                <div class="course-banner course-banner-2">📈</div>
                <div class="course-body">
                    <span class="course-tag">New</span>
                    <div class="course-title">Social Media Growth Blueprint</div>
                    <p class="course-desc">The exact system to grow from 0 to 10K+ followers.</p>
                    <div class="course-footer">
                        <span class="course-price">PKR 3,499</span>
                        <span class="course-btn">Enroll Now</span>
                    </div>
                </div>
            </a>

            <a href="/course-personal-branding" class="course-card reveal" style="text-decoration:none; color:inherit; display:block;">
                <div class="course-banner course-banner-3">💡</div>
                <div class="course-body">
                    <span class="course-tag">Popular</span>
                    <div class="course-title">Personal Branding Bootcamp</div>
                    <p class="course-desc">Build a brand that people remember.</p>
                    <div class="course-footer">
                        <span class="course-price">PKR 2,999</span>
                        <span class="course-btn">Enroll Now</span>
                    </div>
                </div>
            </a>

            <a href="/course-video-editing" class="course-card reveal" style="text-decoration:none; color:inherit; display:block;">
                <div class="course-banner course-banner-1">🎬</div>
                <div class="course-body">
                    <span class="course-tag">Advanced</span>
                    <div class="course-title">Video Editing Pro</div>
                    <p class="course-desc">Master video editing for YouTube, Reels and TikTok.</p>
                    <div class="course-footer">
                        <span class="course-price">PKR 5,999</span>
                        <span class="course-btn">Enroll Now</span>
                    </div>
                </div>
            </a>

            <a href="/course-monetization" class="course-card reveal" style="text-decoration:none; color:inherit; display:block;">
                <div class="course-banner course-banner-2">💰</div>
                <div class="course-body">
                    <span class="course-tag">Hot</span>
                    <div class="course-title">Monetization Secrets</div>
                    <p class="course-desc">Turn your content into a full-time income.</p>
                    <div class="course-footer">
                        <span class="course-price">PKR 6,999</span>
                        <span class="course-btn">Enroll Now</span>
                    </div>
                </div>
            </a>

            <a href="/course-starter-kit" class="course-card reveal" style="text-decoration:none; color:inherit; display:block;">
                <div class="course-banner course-banner-3">🎯</div>
                <div class="course-body">
                    <span class="course-tag">Free</span>
                    <div class="course-title">Creator Starter Kit</div>
                    <p class="course-desc">Free beginner course to get you started.</p>
                    <div class="course-footer">
                        <span class="course-price">FREE</span>
                        <span class="course-btn">Start Now</span>
                    </div>
                </div>
            </a>

        </div>
    </section>

</div>

@code {
    protected override void OnInitialized()
    {
        SiteData.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        SiteData.OnChange -= StateHasChanged;
    }
}
