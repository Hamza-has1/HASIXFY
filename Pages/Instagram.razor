@page "/instagram"
@layout MainLayout

<div class="page-enter">
    <section class="platform-hero" style="background: radial-gradient(ellipse at center, rgba(225,48,108,0.15) 0%, transparent 70%), var(--dark);">
        <div>
            <span class="platform-icon-big"><i class="fab fa-instagram social-icon"></i></span
            <h1 class="platform-title" style="background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Instagram</h1>
            <p class="platform-sub">Visual stories, reels & moments that matter</p>
            <a href="https://instagram.com/hasxify" target="_blank" class="btn-primary" style="background: linear-gradient(135deg, #f09433, #dc2743, #bc1888);">
                Follow on Instagram ↗
            </a>
        </div>
    </section>

    <section class="social-section" style="background: var(--black);">
        <h2 class="section-title">Latest Content</h2>
        <p class="section-subtitle">Reels, posts, stories — all in one place</p>
        <div class="social-grid" style="max-width: 900px;">
            <div class="service-card reveal" style="text-align:center;">
                <span class="service-icon">🎬</span>
                <div class="service-title">Reels</div>
                <p class="service-desc">Short-form videos that entertain, educate and inspire. New reels every week.</p>
            </div>
            <div class="service-card reveal" style="text-align:center;">
                <span class="service-icon">🖼️</span>
                <div class="service-title">Posts</div>
                <p class="service-desc">High-quality visuals, quotes, and behind-the-scenes content.</p>
            </div>
            <div class="service-card reveal" style="text-align:center;">
                <span class="service-icon">📖</span>
                <div class="service-title">Stories</div>
                <p class="service-desc">Daily updates, polls, Q&As, and exclusive behind-the-scenes moments.</p>
            </div>
        </div>
        <div style="text-align:center; margin-top:48px;">
            <a href="https://instagram.com/hasxify" target="_blank" class="btn-primary" style="background: linear-gradient(135deg, #f09433, #dc2743, #bc1888);">
                Open Instagram Profile ↗
            </a>
        </div>
    </section>
</div>