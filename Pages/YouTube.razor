@page "/youtube"
@layout MainLayout

<div class="page-enter">
    <section class="platform-hero" style="background: radial-gradient(ellipse at center, rgba(255,0,0,0.15) 0%, transparent 70%), var(--dark);">
        <div>
            <i class="fab fa-youtube platform-icon-big" style="color:#ff0000;"></i>            <h1 class="platform-title" style="color: #ff0000;">YouTube</h1>
            <p class="platform-sub">Long-form videos, tutorials & vlogs</p>
            <a href="https://youtube.com/@@hasxify" target="_blank" class="btn-primary" style="background: #ff0000;">
                Subscribe Now ↗
            </a>
        </div>
    </section>

    <section class="social-section" style="background: var(--black);">
        <h2 class="section-title">Channel Content</h2>
        <p class="section-subtitle">Quality videos that deliver real value</p>

        <div class="social-grid" style="max-width: 900px;">
            <div class="service-card reveal" style="text-align:center;">
                <span class="service-icon">🎓</span>
                <div class="service-title">Tutorials</div>
                <p class="service-desc">Step-by-step guides on content creation, editing, and growing online.</p>
            </div>
            <div class="service-card reveal" style="text-align:center;">
                <span class="service-icon">🎥</span>
                <div class="service-title">Vlogs</div>
                <p class="service-desc">Behind the scenes of a content creator's life — real and unfiltered.</p>
            </div>
            <div class="service-card reveal" style="text-align:center;">
                <span class="service-icon">💬</span>
                <div class="service-title">Reviews</div>
                <p class="service-desc">Honest reviews on gear, tools, and software used by creators.</p>
            </div>
        </div>

        <div style="text-align:center; margin-top:48px;">
            <a href="https://youtube.com/@@hasxify" target="_blank" class="btn-primary" style="background: #ff0000;">
                Visit YouTube Channel ↗
            </a>
        </div>
    </section>
</div>
