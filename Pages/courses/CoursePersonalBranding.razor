@page "/course-personal-branding"
@layout MainLayout

<div class="page-enter">
    <section class="service-hero" style="background: radial-gradient(ellipse at center, rgba(192,132,252,0.3) 0%, transparent 70%), #000;">
        <div class="service-hero-content">
            <span class="service-hero-icon">💡</span>
            <h1 class="platform-title" style="background: linear-gradient(135deg, #fff, #c084fc); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">Personal Branding Bootcamp</h1>
            <p class="platform-sub">Build a brand that people remember</p>
            <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap; margin-top:16px;">
                <span class="course-tag">🔥 Popular</span>
                <span class="course-tag">👥 1,800+ Students</span>
                <span class="course-tag">⏱️ 12+ Hours</span>
            </div>
        </div>
    </section>

    <section class="services-section">
        <div style="max-width:900px; margin:0 auto;">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:40px;">
                <div>
                    <h2 class="section-title" style="text-align:left; font-size:1.5rem;">What You'll Learn</h2>
                    <div style="margin-top:24px;">
                        @foreach (var item in learnings)
                        {
                            <div style="display:flex; gap:12px; margin-bottom:16px; align-items:flex-start;">
                                <span style="color:#c084fc; font-size:1.2rem;">✓</span>
                                <p style="color:#e2e8f0; font-size:1rem; line-height:1.6;">@item</p>
                            </div>
                        }
                    </div>
                </div>
                <div>
                    <div class="contact-box" style="padding:32px;">
                        <div style="font-family:'Orbitron',sans-serif; font-size:2rem; font-weight:900; color:#c084fc; margin-bottom:8px;">PKR 2,999</div>
                        <p style="color:#888; margin-bottom:24px; font-size:0.9rem;">One-time payment • Lifetime access</p>
                        <a href="/login" class="btn-primary" style="display:block; text-align:center; margin-bottom:12px;">Enroll Now →</a>
                        <a href="/contact" class="btn-outline" style="display:block; text-align:center;">Ask a Question</a>
                        <div style="margin-top:24px; padding-top:24px; border-top:1px solid rgba(124,58,237,0.2);">
                            <div style="color:#888; font-size:0.85rem; margin-bottom:8px;">✅ 30-day money back guarantee</div>
                            <div style="color:#888; font-size:0.85rem; margin-bottom:8px;">✅ Lifetime access</div>
                            <div style="color:#888; font-size:0.85rem; margin-bottom:8px;">✅ Certificate of completion</div>
                            <div style="color:#888; font-size:0.85rem;">✅ Mobile & desktop access</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="courses-section">
        <h2 class="section-title">Course Curriculum</h2>
        <p class="section-subtitle">12+ hours of content across 4 modules</p>
        <div style="max-width:800px; margin:0 auto;">
            @foreach (var module in curriculum)
            {
                <div class="admin-card" style="margin-bottom:16px;">
                    <h4 style="color:#c084fc; font-family:'Orbitron',sans-serif; font-size:0.9rem; letter-spacing:1px; margin-bottom:12px;">@module.Title</h4>
                    <p style="color:#888; font-size:0.9rem;">@module.Topics</p>
                </div>
            }
        </div>
    </section>

    <!-- YOUR FUTURE SECTION -->
    <section class="sp-process-section">
        <h2 class="section-title">Your Future After This Course</h2>
        <p class="section-subtitle">Yeh course khatam karne ke baad aapki life kaise badlegi</p>
        <div class="process-grid">
            @foreach (var f in futures)
            {
                <div class="process-step reveal">
                    <div style="font-size:2.5rem; margin-bottom:16px;">@f.Icon</div>
                    <div class="process-title">@f.Title</div>
                    <p class="process-desc">@f.Desc</p>
                </div>
            }
        </div>
        <div style="text-align:center; margin-top:48px;">
            <a href="/login" class="btn-primary">Build Your Brand Today →</a>
        </div>
    </section>
</div>

@code {
    private List<string> learnings = new()
    {
        "Discovering your unique brand identity and voice",
        "Creating a consistent visual identity across all platforms",
        "Storytelling techniques that connect with your audience",
        "Building authority and credibility in your niche",
        "Networking and collaboration strategies",
        "Managing your online reputation professionally",
        "Creating content that reflects your personal brand",
        "Turning your personal brand into business opportunities",
    };

    private List<ModuleItem> curriculum = new()
    {
        new ModuleItem { Title = "Module 1 — Brand Discovery", Topics = "Finding your niche, defining your audience, brand values and mission" },
        new ModuleItem { Title = "Module 2 — Visual Identity", Topics = "Logo, colors, typography, photography style, consistent aesthetics" },
        new ModuleItem { Title = "Module 3 — Content & Storytelling", Topics = "Your brand story, content pillars, authentic communication" },
        new ModuleItem { Title = "Module 4 — Brand Growth", Topics = "Networking, PR, collaborations, speaking opportunities, monetization" },
    };

    private record FutureItem(string Icon, string Title, string Desc);
    private List<FutureItem> futures = new()
    {
        new("👑", "Recognized Expert", "Aap apni field mein ek recognized name ban jayenge — log aapko recommendations aur advice ke liye follow karein ge."),
        new("🤝", "Premium Clients", "Strong personal brand hone se premium clients attract hote hain jo aapki value samjhte hain aur achi payment dete hain."),
        new("🎤", "Speaking Opportunities", "Events, webinars, podcasts aur panels par invite ane lagte hain jab aapka brand strong hota hai."),
        new("💼", "Career Growth", "Job market mein bhi personal brand ka farak hota hai — aapko better opportunities milti hain doosron se pehle."),
        new("📖", "Your Own Story", "Aapki brand story aapko doosron se alag karti hai — aur log stories ko yaad rakhte hain products ko nahi."),
        new("🌟", "Lasting Legacy", "Ek strong personal brand aapke saath hamesha rehta hai — chahe aap job badlo, business badlo ya kuch naya shuru karo."),
    };
}
