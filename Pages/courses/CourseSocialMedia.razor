@page "/course-social-media-growth"
@layout MainLayout

<div class="page-enter">
    <section class="service-hero" style="background: radial-gradient(ellipse at center, rgba(59,130,246,0.3) 0%, transparent 70%), #000;">
        <div class="service-hero-content">
            <span class="service-hero-icon">📈</span>
            <h1 class="platform-title" style="background: linear-gradient(135deg, #fff, #60a5fa); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">Social Media Growth Blueprint</h1>
            <p class="platform-sub">The exact system to grow from 0 to 10K+ followers</p>
            <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap; margin-top:16px;">
                <span class="course-tag">🆕 New</span>
                <span class="course-tag">👥 1,200+ Students</span>
                <span class="course-tag">⏱️ 15+ Hours</span>
            </div>
        </div>
    </section>

    <section class="services-section">
        <div style="max-width:900px; margin:0 auto;">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:40px;">
                <div>
                    <h2 class="section-title" style="text-align:left; font-size:1.5rem;">What You'll Learn</h2>
                    <div style="margin-top:24px;">
                        @foreach (var item in learnings)
                        {
                            <div style="display:flex; gap:12px; margin-bottom:16px; align-items:flex-start;">
                                <span style="color:#60a5fa; font-size:1.2rem;">✓</span>
                                <p style="color:#e2e8f0; font-size:1rem; line-height:1.6;">@item</p>
                            </div>
                        }
                    </div>
                </div>
                <div>
                    <div class="contact-box" style="padding:32px;">
                        <div style="font-family:'Orbitron',sans-serif; font-size:2rem; font-weight:900; color:#60a5fa; margin-bottom:8px;">PKR 3,499</div>
                        <p style="color:#888; margin-bottom:24px; font-size:0.9rem;">One-time payment • Lifetime access</p>
                        <a href="/login" class="btn-primary" style="display:block; text-align:center; margin-bottom:12px; background:linear-gradient(135deg,#1e3a8a,#3b82f6);">Enroll Now →</a>
                        <a href="/contact" class="btn-outline" style="display:block; text-align:center;">Ask a Question</a>
                        <div style="margin-top:24px; padding-top:24px; border-top:1px solid rgba(124,58,237,0.2);">
                            <div style="color:#888; font-size:0.85rem; margin-bottom:8px;">✅ 30-day money back guarantee</div>
                            <div style="color:#888; font-size:0.85rem; margin-bottom:8px;">✅ Lifetime access</div>
                            <div style="color:#888; font-size:0.85rem; margin-bottom:8px;">✅ Certificate of completion</div>
                            <div style="color:#888; font-size:0.85rem;">✅ Mobile & desktop access</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="courses-section">
        <h2 class="section-title">Course Curriculum</h2>
        <p class="section-subtitle">15+ hours of content across 5 modules</p>
        <div style="max-width:800px; margin:0 auto;">
            @foreach (var module in curriculum)
            {
                <div class="admin-card" style="margin-bottom:16px;">
                    <h4 style="color:#60a5fa; font-family:'Orbitron',sans-serif; font-size:0.9rem; letter-spacing:1px; margin-bottom:12px;">@module.Title</h4>
                    <p style="color:#888; font-size:0.9rem;">@module.Topics</p>
                </div>
            }
        </div>
    </section>

    <!-- YOUR FUTURE SECTION -->
    <section class="sp-process-section">
        <h2 class="section-title">Your Future After This Course</h2>
        <p class="section-subtitle">Yeh course khatam karne ke baad aapki life kaise badlegi</p>
        <div class="process-grid">
            @foreach (var f in futures)
            {
                <div class="process-step reveal">
                    <div style="font-size:2.5rem; margin-bottom:16px;">@f.Icon</div>
                    <div class="process-title">@f.Title</div>
                    <p class="process-desc">@f.Desc</p>
                </div>
            }
        </div>
        <div style="text-align:center; margin-top:48px;">
            <a href="/login" class="btn-primary" style="background:linear-gradient(135deg,#1e3a8a,#3b82f6);">Start Growing Today →</a>
        </div>
    </section>
</div>

@code {
    private List<string> learnings = new()
    {
        "Platform-specific growth strategies for Instagram, TikTok & YouTube",
        "Profile optimization to attract the right audience",
        "Content formats that get maximum reach and engagement",
        "Hashtag research and SEO strategies that actually work",
        "How to go viral — the science behind shareability",
        "Engagement tactics to build a loyal community",
        "Collaboration and cross-promotion strategies",
        "Analytics interpretation for data-driven decisions",
    };

    private List<ModuleItem> curriculum = new()
    {
        new ModuleItem { Title = "Module 1 — Profile Setup", Topics = "Bio optimization, profile picture, highlights, link in bio strategy" },
        new ModuleItem { Title = "Module 2 — Content System", Topics = "Content pillars, posting frequency, batch creation, repurposing content" },
        new ModuleItem { Title = "Module 3 — Growth Hacks", Topics = "Algorithm secrets, hashtag strategy, engagement pods, viral triggers" },
        new ModuleItem { Title = "Module 4 — Community Building", Topics = "DM strategy, comments, stories engagement, building superfans" },
        new ModuleItem { Title = "Module 5 — Scale & Monetize", Topics = "Paid promotions, brand deals, affiliate links, product launches" },
    };

    private record FutureItem(string Icon, string Title, string Desc);
    private List<FutureItem> futures = new()
    {
        new("📱", "10K+ Followers", "3 se 6 mahine mein aap consistently 10,000+ followers tak pohonch sakte hain — har platform par organic growth ke saath."),
        new("🔥", "Viral Content", "Aapko exact pata hoga kaunsa content viral hota hai aur kyun — aur aap isse apni niche mein apply kar sakte hain."),
        new("🤝", "Brand Deals", "Jab following grow hogi to brands khud aapse contact karein ge sponsored content ke liye."),
        new("📊", "Data-Driven Creator", "Aap analytics samajhne lage to — guess work khatam, sirf results pe focus."),
        new("🌍", "Online Influence", "Aapki community aap par trust karegi aur aap apni field mein ek reliable voice ban jayenge."),
        new("💸", "Passive Income", "Social media presence se affiliate links, digital products aur collaborations ke zariye passive income shuru ho sakti hai."),
    };
}
