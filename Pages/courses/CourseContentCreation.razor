@page "/course-content-creation"
@layout MainLayout

<div class="page-enter">
    <section class="service-hero" style="background: radial-gradient(ellipse at center, rgba(124,58,237,0.3) 0%, transparent 70%), #000;">
        <div class="service-hero-content">
            <span class="service-hero-icon">🚀</span>
            <h1 class="platform-title" style="background: linear-gradient(135deg, #fff, #c084fc); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">Content Creation Masterclass</h1>
            <p class="platform-sub">Everything you need to go from zero to viral</p>
            <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap; margin-top:16px;">
                <span class="course-tag">⭐ Bestseller</span>
                <span class="course-tag">👥 2,500+ Students</span>
                <span class="course-tag">⏱️ 20+ Hours</span>
            </div>
        </div>
    </section>

    <section class="services-section">
        <div style="max-width:900px; margin:0 auto;">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:40px;">
                <div>
                    <h2 class="section-title" style="text-align:left; font-size:1.5rem;">What You'll Learn</h2>
                    <div style="margin-top:24px;">
                        @foreach (var item in learnings)
                        {
                            <div style="display:flex; gap:12px; margin-bottom:16px; align-items:flex-start;">
                                <span style="color:#a855f7; font-size:1.2rem;">✓</span>
                                <p style="color:#e2e8f0; font-size:1rem; line-height:1.6;">@item</p>
                            </div>
                        }
                    </div>
                </div>
                <div>
                    <div class="contact-box" style="padding:32px;">
                        <div style="font-family:'Orbitron',sans-serif; font-size:2rem; font-weight:900; color:#a855f7; margin-bottom:8px;">PKR 4,999</div>
                        <p style="color:#888; margin-bottom:24px; font-size:0.9rem;">One-time payment • Lifetime access</p>
                        <a href="/login" class="btn-primary" style="display:block; text-align:center; margin-bottom:12px;">Enroll Now →</a>
                        <a href="/contact" class="btn-outline" style="display:block; text-align:center;">Ask a Question</a>
                        <div style="margin-top:24px; padding-top:24px; border-top:1px solid rgba(124,58,237,0.2);">
                            <div style="color:#888; font-size:0.85rem; margin-bottom:8px;">✅ 30-day money back guarantee</div>
                            <div style="color:#888; font-size:0.85rem; margin-bottom:8px;">✅ Lifetime access</div>
                            <div style="color:#888; font-size:0.85rem; margin-bottom:8px;">✅ Certificate of completion</div>
                            <div style="color:#888; font-size:0.85rem;">✅ Mobile & desktop access</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="courses-section">
        <h2 class="section-title">Course Curriculum</h2>
        <p class="section-subtitle">20+ hours of content across 6 modules</p>
        <div style="max-width:800px; margin:0 auto;">
            @foreach (var module in curriculum)
            {
                <div class="admin-card" style="margin-bottom:16px;">
                    <h4 style="color:#a855f7; font-family:'Orbitron',sans-serif; font-size:0.9rem; letter-spacing:1px; margin-bottom:12px;">@module.Title</h4>
                    <p style="color:#888; font-size:0.9rem;">@module.Topics</p>
                </div>
            }
        </div>
    </section>

    <!-- YOUR FUTURE SECTION -->
    <section class="sp-process-section">
        <h2 class="section-title">Your Future After This Course</h2>
        <p class="section-subtitle">Yeh course khatam karne ke baad aapki life kaise badlegi</p>
        <div class="process-grid">
            @foreach (var f in futures)
            {
                <div class="process-step reveal">
                    <div style="font-size:2.5rem; margin-bottom:16px;">@f.Icon</div>
                    <div class="process-title">@f.Title</div>
                    <p class="process-desc">@f.Desc</p>
                </div>
            }
        </div>
        <div style="text-align:center; margin-top:48px;">
            <a href="/login" class="btn-primary">Start Your Journey Today →</a>
        </div>
    </section>
</div>

@code {
    private List<string> learnings = new()
    {
        "How to set up your content creation studio on any budget",
        "Camera techniques, lighting and audio setup",
        "Video editing from beginner to advanced level",
        "Content strategy and planning for consistent growth",
        "How to grow on YouTube, Instagram and TikTok simultaneously",
        "Monetization strategies to turn your content into income",
        "Building a personal brand that stands out",
        "Analytics and data-driven content optimization",
    };

    private List<ModuleItem> curriculum = new()
    {
        new ModuleItem { Title = "Module 1 — Foundation", Topics = "Introduction to content creation, equipment setup, finding your niche" },
        new ModuleItem { Title = "Module 2 — Production", Topics = "Camera operation, lighting techniques, audio recording, studio setup" },
        new ModuleItem { Title = "Module 3 — Editing", Topics = "Video editing software, color grading, transitions, effects, thumbnails" },
        new ModuleItem { Title = "Module 4 — Strategy", Topics = "Content planning, posting schedules, hashtags, SEO for videos" },
        new ModuleItem { Title = "Module 5 — Growth", Topics = "Algorithm mastery, collaborations, viral content secrets, audience building" },
        new ModuleItem { Title = "Module 6 — Monetization", Topics = "Brand deals, AdSense, affiliate marketing, digital products, memberships" },
    };

    private record FutureItem(string Icon, string Title, string Desc);
    private List<FutureItem> futures = new()
    {
        new("🎥", "Full-Time Creator", "Aap apna khud ka YouTube, Instagram aur TikTok channel professionally run kar sakte hain — sirf passion se nahi, strategy se."),
        new("💼", "Freelance Career", "Brands aur businesses ke liye content banao aur per project PKR 20,000 se 100,000+ tak earn karo."),
        new("🏆", "Personal Brand", "Log aapko apne niche mein expert maanen ge. Aapki opinion matter karegi aur aapki audience aap par trust karegi."),
        new("💰", "Multiple Income Streams", "AdSense, brand deals, courses, affiliate marketing — ek saal ke andar multiple income sources set ho sakte hain."),
        new("📱", "Viral Content", "Aapko pata hoga exact formula jo content ko viral banata hai — aur aap isse bar bar repeat kar sakte hain."),
        new("🚀", "Dream Life", "Location independent life — ghar se, cafe se, ya duniya ke kisi bhi corner se kaam karo aur apni schedule khud banao."),
    };
}
