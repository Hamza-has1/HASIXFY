@page "/courses"
@layout MainLayout

<div class="page-enter">
    <section class="platform-hero" style="background: radial-gradient(ellipse at center, rgba(124,58,237,0.2) 0%, transparent 70%), var(--dark);">
        <div>
            <span class="platform-icon-big">📚</span>
            <h1 class="platform-title" style="background: linear-gradient(135deg, #fff, #c084fc); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">My Courses</h1>
            <p class="platform-sub">Learn what actually works in the digital world</p>
        </div>
    </section>

    <section class="courses-section">
        <h2 class="section-title">All Courses</h2>
        <p class="section-subtitle">Enroll today and start growing</p>
        <div class="courses-grid">
            <div class="course-card reveal">
                <div class="course-banner course-banner-1">🚀</div>
                <div class="course-body">
                    <span class="course-tag">Bestseller</span>
                    <div class="course-title">Content Creation Masterclass</div>
                    <p class="course-desc">Everything you need to go from zero to viral. Camera, editing, strategy, mindset.</p>
                    <div class="course-footer">
                        <span class="course-price">PKR 4,999</span>
                        <a href="/course-content-creation" class="course-btn" style="text-decoration:none;">Enroll Now</a>
                    </div>
                </div>
            </div>
            <div class="course-card reveal">
                <div class="course-banner course-banner-2">📈</div>
                <div class="course-body">
                    <span class="course-tag">New</span>
                    <div class="course-title">Social Media Growth Blueprint</div>
                    <p class="course-desc">The exact system to grow from 0 to 10K+ followers on any platform.</p>
                    <div class="course-footer">
                        <span class="course-price">PKR 3,499</span>
                        <a href="/course-social-media-growth" class="course-btn" style="text-decoration:none;">Enroll Now</a>
                    </div>
                </div>
            </div>
            <div class="course-card reveal">
                <div class="course-banner course-banner-3">💡</div>
                <div class="course-body">
                    <span class="course-tag">Popular</span>
                    <div class="course-title">Personal Branding Bootcamp</div>
                    <p class="course-desc">Build a brand that people remember. Stand out in a crowded digital space.</p>
                    <div class="course-footer">
                        <span class="course-price">PKR 2,999</span>
                        <a href="/course-personal-branding" class="course-btn" style="text-decoration:none;">Enroll Now</a>
                    </div>
                </div>
            </div>
            <div class="course-card reveal">
                <div class="course-banner course-banner-1">🎬</div>
                <div class="course-body">
                    <span class="course-tag">Advanced</span>
                    <div class="course-title">Video Editing Pro</div>
                    <p class="course-desc">Master video editing for YouTube, Reels and TikTok from scratch.</p>
                    <div class="course-footer">
                        <span class="course-price">PKR 5,999</span>
                        <a href="/course-video-editing" class="course-btn" style="text-decoration:none;">Enroll Now</a>
                    </div>
                </div>
            </div>
            <div class="course-card reveal">
                <div class="course-banner course-banner-2">💰</div>
                <div class="course-body">
                    <span class="course-tag">Hot</span>
                    <div class="course-title">Monetization Secrets</div>
                    <p class="course-desc">Turn your content into a full-time income. Sponsorships, affiliate, products.</p>
                    <div class="course-footer">
                        <span class="course-price">PKR 6,999</span>
                        <a href="/course-monetization" class="course-btn" style="text-decoration:none;">Enroll Now</a>
                    </div>
                </div>
            </div>
            <div class="course-card reveal">
                <div class="course-banner course-banner-3">🎯</div>
                <div class="course-body">
                    <span class="course-tag">Free</span>
                    <div class="course-title">Creator Starter Kit</div>
                    <p class="course-desc">Free beginner course to get you started on your content creator journey.</p>
                    <div class="course-footer">
                        <span class="course-price">FREE</span>
                        <a href="/course-starter-kit" class="course-btn" style="text-decoration:none;">Start Now</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>