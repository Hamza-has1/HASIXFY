@page "/course-monetization"
@layout MainLayout

<div class="page-enter">
    <section class="service-hero" style="background: radial-gradient(ellipse at center, rgba(234,179,8,0.2) 0%, transparent 70%), #000;">
        <div class="service-hero-content">
            <span class="service-hero-icon">💰</span>
            <h1 class="platform-title" style="background: linear-gradient(135deg, #fff, #fbbf24); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">Monetization Secrets</h1>
            <p class="platform-sub">Turn your content into a full-time income</p>
            <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap; margin-top:16px;">
                <span class="course-tag">🔥 Hot</span>
                <span class="course-tag">👥 700+ Students</span>
                <span class="course-tag">⏱️ 18+ Hours</span>
            </div>
        </div>
    </section>

    <section class="services-section">
        <div style="max-width:900px; margin:0 auto;">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:40px;">
                <div>
                    <h2 class="section-title" style="text-align:left; font-size:1.5rem;">What You'll Learn</h2>
                    <div style="margin-top:24px;">
                        @foreach (var item in learnings)
                        {
                            <div style="display:flex; gap:12px; margin-bottom:16px; align-items:flex-start;">
                                <span style="color:#fbbf24; font-size:1.2rem;">✓</span>
                                <p style="color:#e2e8f0; font-size:1rem; line-height:1.6;">@item</p>
                            </div>
                        }
                    </div>
                </div>
                <div>
                    <div class="contact-box" style="padding:32px;">
                        <div style="font-family:'Orbitron',sans-serif; font-size:2rem; font-weight:900; color:#fbbf24; margin-bottom:8px;">PKR 6,999</div>
                        <p style="color:#888; margin-bottom:24px; font-size:0.9rem;">One-time payment • Lifetime access</p>
                        <a href="/login" class="btn-primary" style="display:block; text-align:center; margin-bottom:12px; background:linear-gradient(135deg,#92400e,#f59e0b);">Enroll Now →</a>
                        <a href="/contact" class="btn-outline" style="display:block; text-align:center;">Ask a Question</a>
                        <div style="margin-top:24px; padding-top:24px; border-top:1px solid rgba(124,58,237,0.2);">
                            <div style="color:#888; font-size:0.85rem; margin-bottom:8px;">✅ 30-day money back guarantee</div>
                            <div style="color:#888; font-size:0.85rem; margin-bottom:8px;">✅ Lifetime access</div>
                            <div style="color:#888; font-size:0.85rem; margin-bottom:8px;">✅ Certificate of completion</div>
                            <div style="color:#888; font-size:0.85rem;">✅ Mobile & desktop access</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="courses-section">
        <h2 class="section-title">Course Curriculum</h2>
        <p class="section-subtitle">18+ hours of content across 5 modules</p>
        <div style="max-width:800px; margin:0 auto;">
            @foreach (var module in curriculum)
            {
                <div class="admin-card" style="margin-bottom:16px;">
                    <h4 style="color:#fbbf24; font-family:'Orbitron',sans-serif; font-size:0.9rem; letter-spacing:1px; margin-bottom:12px;">@module.Title</h4>
                    <p style="color:#888; font-size:0.9rem;">@module.Topics</p>
                </div>
            }
        </div>
    </section>

    <!-- YOUR FUTURE SECTION -->
    <section class="sp-process-section">
        <h2 class="section-title">Your Future After This Course</h2>
        <p class="section-subtitle">Yeh course khatam karne ke baad aapki life kaise badlegi</p>
        <div class="process-grid">
            @foreach (var f in futures)
            {
                <div class="process-step reveal">
                    <div style="font-size:2.5rem; margin-bottom:16px;">@f.Icon</div>
                    <div class="process-title">@f.Title</div>
                    <p class="process-desc">@f.Desc</p>
                </div>
            }
        </div>
        <div style="text-align:center; margin-top:48px;">
            <a href="/login" class="btn-primary" style="background:linear-gradient(135deg,#92400e,#f59e0b);">Start Earning Today →</a>
        </div>
    </section>
</div>

@code {
    private List<string> learnings = new()
    {
        "YouTube AdSense — how to qualify and maximize revenue",
        "Brand sponsorships — how to pitch and negotiate deals",
        "Affiliate marketing strategies for content creators",
        "Creating and selling digital products and courses",
        "Membership communities and subscription income",
        "Freelancing your content skills for clients",
        "Building multiple income streams simultaneously",
        "Tax and financial basics for content creators",
    };

    private List<ModuleItem> curriculum = new()
    {
        new ModuleItem { Title = "Module 1 — Monetization Mindset", Topics = "Income streams overview, building an audience first, monetization readiness" },
        new ModuleItem { Title = "Module 2 — Ad Revenue", Topics = "YouTube Partner Program, AdSense, CPM optimization, ad placement" },
        new ModuleItem { Title = "Module 3 — Brand Deals", Topics = "Finding brands, media kit creation, pitching, contracts, rates" },
        new ModuleItem { Title = "Module 4 — Digital Products", Topics = "Courses, ebooks, presets, templates — creation and sales funnels" },
        new ModuleItem { Title = "Module 5 — Scale & Automate", Topics = "Team building, outsourcing, passive income, financial planning" },
    };

    private record FutureItem(string Icon, string Title, string Desc);
    private List<FutureItem> futures = new()
    {
        new("💰", "Full-Time Income", "Content creator ban ke full-time income kamana possible hai — is course ke baad aapke paas exact roadmap hoga apna pehla PKR 1 lakh online earn karne ka."),
        new("🤑", "Multiple Streams", "Sirf ek platform par depend mat karo — AdSense, brand deals, affiliate, courses — sab ek saath chalao."),
        new("📧", "Brand Deals", "Aap khud brands ko pitch kar sakte hain ya unhe attract kar sakte hain — ek sponsored post se PKR 10,000 se 200,000+ tak earn ho sakta hai."),
        new("🛒", "Digital Products", "Apna khud ka course, ebook ya preset pack launch karo — ek baar banao, baar baar becho."),
        new("📈", "Scalable Business", "Content se ek real scalable business banana — employees, systems, automation — sab is course mein cover hai."),
        new("🏖️", "Financial Freedom", "Jab income passive ho jaye to aap kahi se bhi kaam kar sakte hain — yeh sirf dream nahi, yeh aapka next step hai."),
    };
}
