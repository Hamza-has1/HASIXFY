@page "/enroll/dashboard"
@layout MainLayout

<div class="page-enter">
    <section style="padding-top:100px; padding-bottom:60px; max-width:1200px; margin:0 auto; padding-left:40px; padding-right:40px;">

        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:40px; flex-wrap:wrap; gap:16px;">
            <div>
                <p style="color:#a855f7; font-size:0.85rem; letter-spacing:2px; text-transform:uppercase; margin-bottom:8px;">Welcome Back 👋</p>
                <h1 style="font-family:'Orbitron',sans-serif; color:white; font-size:1.8rem; letter-spacing:3px;">HASXIFY Student</h1>
                <p style="color:#888; margin-top:4px;">Keep learning, keep growing!</p>
            </div>
            <a href="/enroll/profile" class="btn-outline" style="font-size:0.85rem; padding:10px 20px;">👤 My Profile</a>
        </div>

        <!-- Stats -->
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:20px; margin-bottom:40px;">
            <div class="admin-card" style="text-align:center; padding:28px;">
                <div style="font-size:2.5rem; margin-bottom:12px;">📚</div>
                <div style="font-family:'Orbitron',sans-serif; font-size:1.8rem; font-weight:900; color:#a855f7; margin-bottom:4px;">@enrolledCourses</div>
                <div style="color:#888; font-size:0.85rem; text-transform:uppercase; letter-spacing:1px;">Enrolled Courses</div>
            </div>
            <div class="admin-card" style="text-align:center; padding:28px;">
                <div style="font-size:2.5rem; margin-bottom:12px;">⏰</div>
                <div style="font-family:'Orbitron',sans-serif; font-size:1.8rem; font-weight:900; color:#a855f7; margin-bottom:4px;">@totalHours</div>
                <div style="color:#888; font-size:0.85rem; text-transform:uppercase; letter-spacing:1px;">Hours Studied</div>
            </div>
            <div class="admin-card" style="text-align:center; padding:28px;">
                <div style="font-size:2.5rem; margin-bottom:12px;">🔥</div>
                <div style="font-family:'Orbitron',sans-serif; font-size:1.8rem; font-weight:900; color:#a855f7; margin-bottom:4px;">@streak</div>
                <div style="color:#888; font-size:0.85rem; text-transform:uppercase; letter-spacing:1px;">Day Streak</div>
            </div>
            <div class="admin-card" style="text-align:center; padding:28px;">
                <div style="font-size:2.5rem; margin-bottom:12px;">🏆</div>
                <div style="font-family:'Orbitron',sans-serif; font-size:1.8rem; font-weight:900; color:#a855f7; margin-bottom:4px;">@certificates</div>
                <div style="color:#888; font-size:0.85rem; text-transform:uppercase; letter-spacing:1px;">Certificates</div>
            </div>
        </div>

        <!-- Daily Study Tracker -->
        <div class="admin-section" style="margin-bottom:32px;">
            <h3 class="admin-section-title">⏱️ Today's Study Tracker</h3>
            <div style="display:flex; align-items:center; gap:24px; flex-wrap:wrap;">
                <div style="flex:1; min-width:200px;">
                    <p style="color:#888; margin-bottom:12px; font-size:0.9rem;">Daily Goal: <span style="color:#a855f7; font-weight:700;">@dailyGoal hours</span></p>
                    <div style="background:rgba(124,58,237,0.1); border-radius:50px; height:12px; overflow:hidden;">
                        <div style="background:linear-gradient(90deg,#7c3aed,#a855f7); height:100%; width:@(todayProgress)%; border-radius:50px; transition:width 0.5s;"></div>
                    </div>
                    <p style="color:#888; margin-top:8px; font-size:0.85rem;">@todayHours / @dailyGoal hours today</p>
                </div>
                <div style="display:flex; gap:12px;">
                    <button class="btn-outline" style="padding:10px 20px; font-size:0.85rem;" @onclick="RemoveHour">− 30 min</button>
                    <button class="btn-primary" style="padding:10px 20px; font-size:0.85rem;" @onclick="AddHour">+ 30 min</button>
                </div>
            </div>
        </div>

        <!-- Course Progress -->
        <div class="admin-section" style="margin-bottom:32px;">
            <h3 class="admin-section-title">📊 Course Progress</h3>
            @foreach (var course in courses)
            {
                <div style="margin-bottom:24px; padding:20px; background:rgba(124,58,237,0.05); border:1px solid rgba(124,58,237,0.15); border-radius:16px;">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; flex-wrap:wrap; gap:8px;">
                        <div style="display:flex; align-items:center; gap:12px;">
                            <span style="font-size:1.5rem;">@course.Icon</span>
                            <div>
                                <div style="font-family:'Orbitron',sans-serif; color:white; font-size:0.85rem; font-weight:700;">@course.Name</div>
                                <div style="color:#888; font-size:0.75rem;">@course.Field</div>
                            </div>
                        </div>
                        <div style="display:flex; align-items:center; gap:12px;">
                            <span style="color:#a855f7; font-family:'Orbitron',sans-serif; font-size:0.9rem; font-weight:700;">@course.Progress%</span>
                            <a href="/enroll/my-courses" class="course-btn" style="text-decoration:none; font-size:0.75rem; padding:6px 16px;">Continue →</a>
                        </div>
                    </div>
                    <div style="background:rgba(124,58,237,0.1); border-radius:50px; height:8px; overflow:hidden;">
                        <div style="background:linear-gradient(90deg,#7c3aed,#c084fc); height:100%; width:@(course.Progress)%; border-radius:50px;"></div>
                    </div>
                </div>
            }
            <a href="/enroll/my-courses" class="btn-outline" style="display:inline-block; margin-top:8px; font-size:0.85rem;">View All Courses →</a>
        </div>

        <!-- Weekly Chart -->
        <div class="admin-section" style="margin-bottom:32px;">
            <h3 class="admin-section-title">📅 Weekly Study Hours</h3>
            <div style="display:flex; align-items:flex-end; gap:12px; height:150px; padding:20px 0;">
                @foreach (var day in weeklyData)
                {
                    <div style="flex:1; display:flex; flex-direction:column; align-items:center; gap:8px;">
                        <span style="color:#a855f7; font-size:0.75rem; font-weight:700;">@day.Hours h</span>
                        <div style="width:100%; background:linear-gradient(180deg,#7c3aed,#4c1d95); border-radius:8px 8px 0 0; height:@(day.Hours * 20)px; min-height:4px;"></div>
                        <span style="color:#888; font-size:0.75rem;">@day.Day</span>
                    </div>
                }
            </div>
        </div>

        <!-- Achievements -->
        <div class="admin-section">
            <h3 class="admin-section-title">🏆 Achievements</h3>
            <div style="display:flex; gap:16px; flex-wrap:wrap;">
                @foreach (var badge in badges)
                {
                    <div style="text-align:center; padding:20px; background:rgba(124,58,237,0.08); border:1px solid rgba(124,58,237,0.2); border-radius:16px; min-width:100px;">
                        <div style="font-size:2.5rem; margin-bottom:8px;">@badge.Icon</div>
                        <div style="color:white; font-size:0.75rem; font-weight:700; font-family:'Orbitron',sans-serif; letter-spacing:1px;">@badge.Name</div>
                    </div>
                }
            </div>
        </div>

    </section>
</div>

@code {
    private int enrolledCourses = 3;
    private int totalHours = 24;
    private int streak = 7;
    private int certificates = 1;
    private int dailyGoal = 2;
    private double todayHours = 0.5;
    private double todayProgress => Math.Min((todayHours / dailyGoal) * 100, 100);

    private void AddHour()
    {
        todayHours = Math.Min(todayHours + 0.5, dailyGoal + 2);
        totalHours++;
    }

    private void RemoveHour()
    {
        todayHours = Math.Max(todayHours - 0.5, 0);
    }

    private class DashCourse
    {
        public string Icon { get; set; } = "";
        public string Name { get; set; } = "";
        public string Field { get; set; } = "";
        public int Progress { get; set; }
    }

    private class DashDay
    {
        public string Day { get; set; } = "";
        public int Hours { get; set; }
    }

    private class DashBadge
    {
        public string Icon { get; set; } = "";
        public string Name { get; set; } = "";
    }

    private List<DashCourse> courses = new()
    {
        new DashCourse { Icon = "🚀", Name = "Content Creation Masterclass", Field = "Content Creation", Progress = 65 },
        new DashCourse { Icon = "📈", Name = "Social Media Growth Blueprint", Field = "Social Media", Progress = 30 },
        new DashCourse { Icon = "💡", Name = "Personal Branding Bootcamp", Field = "Branding", Progress = 10 },
    };

    private List<DashDay> weeklyData = new()
    {
        new DashDay { Day = "Mon", Hours = 2 },
        new DashDay { Day = "Tue", Hours = 3 },
        new DashDay { Day = "Wed", Hours = 1 },
        new DashDay { Day = "Thu", Hours = 4 },
        new DashDay { Day = "Fri", Hours = 2 },
        new DashDay { Day = "Sat", Hours = 5 },
        new DashDay { Day = "Sun", Hours = 0 },
    };

    private List<DashBadge> badges = new()
    {
        new DashBadge { Icon = "🌟", Name = "First Step" },
        new DashBadge { Icon = "🔥", Name = "7 Day Streak" },
        new DashBadge { Icon = "📚", Name = "Bookworm" },
        new DashBadge { Icon = "⚡", Name = "Fast Learner" },
    };
}