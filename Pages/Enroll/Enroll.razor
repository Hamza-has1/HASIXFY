@page "/enroll"
@layout MainLayout
@inject NavigationManager Navigation

<div class="page-enter">
    <section class="contact-section" style="padding-top:120px; padding-bottom:60px;">

        <div style="text-align:center; margin-bottom:40px;">
            <div style="font-size:3.5rem; margin-bottom:16px;">🎓</div>
            <h2 class="section-title">Join HASXIFY</h2>
            <p class="section-subtitle">Create your account or sign in to continue</p>
        </div>

        <div class="auth-tabs">
            <button class="auth-tab @(showLogin ? "active" : "")" @onclick="() => { showLogin = true; }">
                🔐 Sign In
            </button>
            <button class="auth-tab @(!showLogin ? "active" : "")" @onclick="() => { showLogin = false; }">
                🎓 Enroll Now
            </button>
        </div>

        @if (showLogin)
        {
            <div class="contact-box auth-box" style="max-width:500px;">
                <div style="text-align:center; margin-bottom:28px;">
                    <span style="font-size:2.5rem;">👋</span>
                    <h3 class="auth-title">Welcome Back!</h3>
                    <p class="auth-sub">Sign in to your HASXIFY account</p>
                </div>

                <input class="contact-input" type="email" placeholder="Email Address *" @bind="loginEmail" />
                <input class="contact-input" type="password" placeholder="Password *" @bind="loginPassword" />

                <div style="text-align:right; margin-bottom:20px;">
                    <span style="color:#a855f7; font-size:0.85rem; cursor:pointer;">Forgot Password?</span>
                </div>

                @if (!string.IsNullOrEmpty(loginError))
                {
                    <p class="auth-error">⚠️ @loginError</p>
                }
                @if (loginSuccess)
                {
                    <p class="auth-success">✓ Login successful! Redirecting...</p>
                }

                <button class="btn-primary" style="width:100%;" @onclick="HandleLogin">
                    @(loginSuccess ? "✓ Logged In!" : "Sign In →")
                </button>

                <div class="auth-divider"><span>or continue with</span></div>

                <div class="social-login-btns">
                    <button class="social-login-btn"><span>G</span> Google</button>
                    <button class="social-login-btn"><span>f</span> Facebook</button>
                </div>

                <div class="auth-switch">
                    Don't have an account?
                    <span @onclick="() => showLogin = false">Enroll Now</span>
                </div>
            </div>
        }
        else
        {
            <div class="contact-box auth-box" style="max-width:600px;">
                <div style="text-align:center; margin-bottom:28px;">
                    <span style="font-size:2.5rem;">🚀</span>
                    <h3 class="auth-title">Create Account</h3>
                    <p class="auth-sub">Join the HASXIFY learning community</p>
                </div>

                <div class="input-grid">
                    <div class="admin-field">
                        <label style="display:block; color:#a855f7; font-size:0.8rem; font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-bottom:6px;">Full Name *</label>
                        <input class="contact-input" style="margin-bottom:0;" type="text" placeholder="Enter your full name" @bind="fullName" />
                    </div>
                    <div class="admin-field">
                        <label style="display:block; color:#a855f7; font-size:0.8rem; font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-bottom:6px;">Father Name *</label>
                        <input class="contact-input" style="margin-bottom:0;" type="text" placeholder="Enter father's name" @bind="fatherName" />
                    </div>
                </div>
                <div style="height:16px;"></div>

                <div class="input-grid">
                    <div class="admin-field">
                        <label style="display:block; color:#a855f7; font-size:0.8rem; font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-bottom:6px;">Age *</label>
                        <input class="contact-input" style="margin-bottom:0;" type="number" placeholder="Your age" @bind="age" min="10" max="60" />
                    </div>
                    <div class="admin-field">
                        <label style="display:block; color:#a855f7; font-size:0.8rem; font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-bottom:6px;">City *</label>
                        <input class="contact-input" style="margin-bottom:0;" type="text" placeholder="Your city" @bind="city" />
                    </div>
                </div>
                <div style="height:16px;"></div>

                <div class="input-grid">
                    <div class="admin-field">
                        <label style="display:block; color:#a855f7; font-size:0.8rem; font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-bottom:6px;">Mobile Number *</label>
                        <input class="contact-input" style="margin-bottom:0;" type="tel" placeholder="03XX-XXXXXXX" @bind="mobile" />
                    </div>
                    <div class="admin-field">
                        <label style="display:block; color:#a855f7; font-size:0.8rem; font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-bottom:6px;">Email Address *</label>
                        <input class="contact-input" style="margin-bottom:0;" type="email" placeholder="your@email.com" @bind="email" />
                    </div>
                </div>
                <div style="height:16px;"></div>

                <div class="admin-field" style="margin-bottom:16px;">
                    <label style="display:block; color:#a855f7; font-size:0.8rem; font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-bottom:6px;">Field of Interest *</label>
                    <select class="contact-input" style="margin-bottom:0; cursor:pointer;" @bind="interest">
                        <option value="">-- Select your interest --</option>
                        <option value="Content Creation">🎬 Content Creation</option>
                        <option value="Video Editing">✂️ Video Editing</option>
                        <option value="Social Media Marketing">📱 Social Media Marketing</option>
                        <option value="Personal Branding">💡 Personal Branding</option>
                        <option value="Monetization">💰 Monetization</option>
                        <option value="Digital Marketing">📊 Digital Marketing</option>
                        <option value="Other">🌟 Other</option>
                    </select>
                </div>

                <div class="input-grid">
                    <div class="admin-field">
                        <label style="display:block; color:#a855f7; font-size:0.8rem; font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-bottom:6px;">Password *</label>
                        <input class="contact-input" style="margin-bottom:0;" type="password" placeholder="Create password" @bind="password" />
                    </div>
                    <div class="admin-field">
                        <label style="display:block; color:#a855f7; font-size:0.8rem; font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-bottom:6px;">Confirm Password *</label>
                        <input class="contact-input" style="margin-bottom:0;" type="password" placeholder="Confirm password" @bind="confirmPassword" />
                    </div>
                </div>
                <div style="height:16px;"></div>

                <div class="terms-check">
                    <input type="checkbox" id="terms" @bind="termsAccepted" />
                    <label for="terms">
                        I agree to the <span style="color:#a855f7; cursor:pointer;">Terms & Conditions</span> and <span style="color:#a855f7; cursor:pointer;">Privacy Policy</span>
                    </label>
                </div>

                @if (!string.IsNullOrEmpty(enrollError))
                {
                    <p class="auth-error">⚠️ @enrollError</p>
                }
                @if (enrollSuccess)
                {
                    <p class="auth-success">🎉 Account created! Welcome to HASXIFY!</p>
                }

                <button class="btn-primary" style="width:100%; margin-top:8px;" @onclick="HandleEnroll">
                    @(enrollSuccess ? "✓ Enrolled!" : "Create Account →")
                </button>

                <div class="auth-switch">
                    Already have an account?
                    <span @onclick="() => showLogin = true">Sign In</span>
                </div>
            </div>
        }

    </section>
</div>

@code {
    private bool showLogin = false;
    private bool loginSuccess = false;
    private bool enrollSuccess = false;
    private string loginError = "";
    private string enrollError = "";

    private string loginEmail = "";
    private string loginPassword = "";

    private string fullName = "";
    private string fatherName = "";
    private string email = "";
    private string password = "";
    private string confirmPassword = "";
    private string mobile = "";
    private string city = "";
    private string interest = "";
    private int age = 0;
    private bool termsAccepted = false;

    private async Task HandleLogin()
    {
        loginError = "";
        if (string.IsNullOrWhiteSpace(loginEmail)) { loginError = "Please enter your email!"; return; }
        if (string.IsNullOrWhiteSpace(loginPassword)) { loginError = "Please enter your password!"; return; }
        loginSuccess = true;
        await Task.Delay(1500);
        Navigation.NavigateTo("/enroll/dashboard");
    }

    private async Task HandleEnroll()
    {
        enrollError = "";
        if (string.IsNullOrWhiteSpace(fullName)) { enrollError = "Please enter your full name!"; return; }
        if (string.IsNullOrWhiteSpace(fatherName)) { enrollError = "Please enter father's name!"; return; }
        if (age < 10 || age > 60) { enrollError = "Please enter a valid age!"; return; }
        if (string.IsNullOrWhiteSpace(city)) { enrollError = "Please enter your city!"; return; }
        if (string.IsNullOrWhiteSpace(mobile)) { enrollError = "Please enter your mobile number!"; return; }
        if (string.IsNullOrWhiteSpace(email)) { enrollError = "Please enter your email!"; return; }
        if (string.IsNullOrWhiteSpace(interest)) { enrollError = "Please select your field of interest!"; return; }
        if (string.IsNullOrWhiteSpace(password)) { enrollError = "Please create a password!"; return; }
        if (password != confirmPassword) { enrollError = "Passwords do not match!"; return; }
        if (!termsAccepted) { enrollError = "Please accept Terms & Conditions!"; return; }

        enrollSuccess = true;
        await Task.Delay(3000);
        enrollSuccess = false;
        fullName = fatherName = email = password = confirmPassword = mobile = city = interest = "";
        age = 0;
        termsAccepted = false;
    }
}