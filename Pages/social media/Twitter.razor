@page "/twitter"
@layout MainLayout

<div class="page-enter">
    <section class="platform-hero" style="background: radial-gradient(ellipse at center, rgba(29,161,242,0.15) 0%, transparent 70%), var(--dark);">
        <div>
            <i class="fab fa-x-twitter platform-icon-big" style="color:#1da1f2;"></i>            <h1 class="platform-title" style="color: #1da1f2;">Twitter / X</h1>
            <p class="platform-sub">Hot takes, threads & creator tips</p>
            <a href="https://twitter.com/hasxify" target="_blank" class="btn-primary" style="background: #1da1f2;">
                Follow on X ↗
            </a>
        </div>
    </section>

    <section class="social-section" style="background: var(--black);">
        <h2 class="section-title">What I Tweet About</h2>
        <p class="section-subtitle">Raw thoughts, creator life & industry news</p>
        <div class="social-grid" style="max-width: 900px;">
            <div class="service-card reveal" style="text-align:center;">
                <span class="service-icon">🔥</span>
                <div class="service-title">Hot Takes</div>
                <p class="service-desc">Unfiltered opinions on the creator economy and social media world.</p>
            </div>
            <div class="service-card reveal" style="text-align:center;">
                <span class="service-icon">🧵</span>
                <div class="service-title">Threads</div>
                <p class="service-desc">Deep-dive threads on content strategy, growth hacks, and more.</p>
            </div>
        </div>
        <div style="text-align:center; margin-top:48px;">
            <a href="https://twitter.com/hasxify" target="_blank" class="btn-primary" style="background: #1da1f2;">
                Follow @@hasxify ↗
            </a>
        </div>
    </section>
</div>