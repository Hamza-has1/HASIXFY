@page "/linkedin"
@layout MainLayout

<div class="page-enter">
    <section class="platform-hero" style="background: radial-gradient(ellipse at center, rgba(0,119,181,0.15) 0%, transparent 70%), var(--dark);">
        <div>
            <span class="platform-icon-big"><i class="fab fa-linkedin social-icon"></i></span>
            <h1 class="platform-title" style="color: #0077b5;">LinkedIn</h1>
            <p class="platform-sub">Professional insights & networking</p>
            <a href="https://linkedin.com/in/hasxify" target="_blank" class="btn-primary" style="background: #0077b5;">
                Connect on LinkedIn ↗
            </a>
        </div>
    </section>

    <section class="social-section" style="background: var(--black);">
        <h2 class="section-title">Professional Content</h2>
        <p class="section-subtitle">Business insights & creator economy updates</p>
        <div class="social-grid" style="max-width: 900px;">
            <div class="service-card reveal" style="text-align:center;">
                <span class="service-icon">📝</span>
                <div class="service-title">Articles</div>
                <p class="service-desc">In-depth articles on content creation, marketing, and personal branding.</p>
            </div>
            <div class="service-card reveal" style="text-align:center;">
                <span class="service-icon">🤝</span>
                <div class="service-title">Networking</div>
                <p class="service-desc">Connecting with brands, creators and professionals worldwide.</p>
            </div>
        </div>
        <div style="text-align:center; margin-top:48px;">
            <a href="https://linkedin.com/in/hasxify" target="_blank" class="btn-primary" style="background: #0077b5;">
                View LinkedIn Profile ↗
            </a>
        </div>
    </section>
</div>