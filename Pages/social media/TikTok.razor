@page "/tiktok"
@layout MainLayout

<div class="page-enter">
    <section class="platform-hero" style="background: radial-gradient(ellipse at center, rgba(0,242,234,0.12) 0%, transparent 70%), var(--dark);">
        <div>
            <i class="fab fa-tiktok platform-icon-big" style="color:#00f2ea;"></i>            <h1 class="platform-title" style="background: linear-gradient(135deg, #00c4bf, #cc0040); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">TikTok</h1>
            <p class="platform-sub">Viral content, trends & entertainment</p>
            <a href="https://tiktok.com/@@hasxify" target="_blank" class="btn-primary" style="background: linear-gradient(135deg, #00f2ea, #ff0050);">
                Follow on TikTok ↗
            </a>
        </div>
    </section>

    <section class="social-section" style="background: var(--black);">
        <h2 class="section-title">TikTok Content</h2>
        <p class="section-subtitle">Short videos that hit different every time</p>

        <div class="social-grid" style="max-width: 900px;">
            <div class="service-card reveal" style="text-align:center;">
                <span class="service-icon">🎯</span>
                <div class="service-title">Trending Content</div>
                <p class="service-desc">Riding trends while keeping it original. New videos daily.</p>
            </div>
            <div class="service-card reveal" style="text-align:center;">
                <span class="service-icon">💥</span>
                <div class="service-title">Creator Tips</div>
                <p class="service-desc">Quick 60-second creator tips that you can apply immediately.</p>
            </div>
        </div>

        <div style="text-align:center; margin-top:48px;">
            <a href="https://tiktok.com/@@hasxify" target="_blank" class="btn-primary" style="background: linear-gradient(135deg, #00f2ea, #ff0050);">
                Follow @@hasxify ↗
            </a>
        </div>
    </section>
</div>