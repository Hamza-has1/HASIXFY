@page "/facebook"
@layout MainLayout

<div class="page-enter">
    <section class="platform-hero" style="background: radial-gradient(ellipse at center, rgba(24,119,242,0.15) 0%, transparent 70%), var(--dark);">
        <div>
            <i class="fab fa-facebook platform-icon-big" style="color:#1877f2;"></i>            <h1 class="platform-title" style="color: #1877f2;">Facebook</h1>
            <p class="platform-sub">Community, live sessions & updates</p>
            <a href="https://facebook.com/hasxify" target="_blank" class="btn-primary" style="background: #1877f2;">
                Like the Page ↗
            </a>
        </div>
    </section>

    <section class="social-section" style="background: var(--black);">
        <h2 class="section-title">Facebook Community</h2>
        <p class="section-subtitle">Join thousands of creators in our community</p>
        <div class="social-grid" style="max-width: 900px;">
            <div class="service-card reveal" style="text-align:center;">
                <span class="service-icon">🔴</span>
                <div class="service-title">Live Sessions</div>
                <p class="service-desc">Regular live Q&As, workshops and creator sessions on Facebook Live.</p>
            </div>
            <div class="service-card reveal" style="text-align:center;">
                <span class="service-icon">👥</span>
                <div class="service-title">Community Group</div>
                <p class="service-desc">An active group for aspiring content creators to share, learn and grow together.</p>
            </div>
        </div>
        <div style="text-align:center; margin-top:48px;">
            <a href="https://facebook.com/hasxify" target="_blank" class="btn-primary" style="background: #1877f2;">
                Visit Facebook Page ↗
            </a>
        </div>
    </section>
</div>