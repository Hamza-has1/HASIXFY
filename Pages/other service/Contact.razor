@page "/contact"
@layout MainLayout
@inject IJSRuntime JS

<div class="page-enter">
    <section class="contact-section" style="padding-top: 120px;">
        <h2 class="section-title">Let's Connect</h2>
        <p class="section-subtitle">Have a project in mind? Let's make it happen.</p>

        <div class="contact-box reveal">
            <div style="margin-bottom: 32px;">
                <span style="font-size: 3rem;">✉️</span>
            </div>

            @if (sent)
            {
                <div style="text-align:center; padding:40px 0;">
                    <div style="font-size:4rem; margin-bottom:16px;">🎉</div>
                    <h3 style="font-family:'Orbitron',sans-serif; color:#a855f7; letter-spacing:2px; margin-bottom:12px;">Message Sent!</h3>
                    <p style="color:#888888;">Thank you! I'll get back to you within 24 hours.</p>
                </div>
            }
            else
            {
                <input class="contact-input" type="text" placeholder="Your Name *" @bind="name" />
                <input class="contact-input" type="email" placeholder="Your Email *" @bind="email" />
                <input class="contact-input" type="text" placeholder="Subject *" @bind="subject" />
                <textarea class="contact-input" placeholder="Your message..." @bind="message"></textarea>

                @if (!string.IsNullOrEmpty(errorMsg))
                {
                    <p style="color:#ff6b6b; margin-bottom:16px; font-size:0.9rem;">⚠️ @errorMsg</p>
                }

                @if (sending)
                {
                    <button class="btn-primary" style="width:100%; margin-top:8px; opacity:0.7;" disabled>
                        ⏳ Sending...
                    </button>
                }
                else
                {
                    <button class="btn-primary" style="width:100%; margin-top:8px;" @onclick="SendMessage">
                        Send Message →
                    </button>
                }
            }
        </div>

        <div style="margin-top: 60px; display: flex; gap: 24px; justify-content: center; flex-wrap: wrap;">
            <a href="https://instagram.com/hasxify" target="_blank" class="btn-outline">
                <i class="fab fa-instagram"></i> Instagram
            </a>
            <a href="https://youtube.com/@@hasxify" target="_blank" class="btn-outline">
                <i class="fab fa-youtube"></i> YouTube
            </a>
            <a href="https://linkedin.com/in/hasxify" target="_blank" class="btn-outline">
                <i class="fab fa-linkedin"></i> LinkedIn
            </a>
        </div>
    </section>
</div>

@code {
    private string name = "";
    private string email = "";
    private string subject = "";
    private string message = "";
    private bool sent = false;
    private bool sending = false;
    private string errorMsg = "";

    private async Task SendMessage()
    {
        errorMsg = "";

        if (string.IsNullOrWhiteSpace(name))
        { errorMsg = "Please enter your name!"; return; }

        if (string.IsNullOrWhiteSpace(email))
        { errorMsg = "Please enter your email!"; return; }

        if (string.IsNullOrWhiteSpace(message))
        { errorMsg = "Please enter your message!"; return; }

        sending = true;

        try
        {
            var result = await JS.InvokeAsync<bool>("sendEmail", name, email, subject, message);

            if (result)
            {
                sent = true;
                name = email = subject = message = "";
            }
            else
            {
                errorMsg = "Failed to send message. Please try again!";
            }
        }
        catch
        {
            errorMsg = "Something went wrong. Please try again!";
        }

        sending = false;
    }
}