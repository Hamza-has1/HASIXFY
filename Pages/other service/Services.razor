@page "/services"
@layout MainLayout

<div class="page-enter">
    <section class="platform-hero" style="background: radial-gradient(ellipse at center, rgba(124,58,237,0.2) 0%, transparent 70%), var(--dark);">
        <div>
            <span class="platform-icon-big">⚡</span>
            <h1 class="platform-title" style="background: linear-gradient(135deg, #6b21a8, #a855f7, #c084fc); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">Services</h1>
            <p class="platform-sub">Professional services to elevate your digital brand</p>
            <a href="/contact" class="btn-primary">Book a Service</a>
        </div>
    </section>

    <section class="services-section">
        <h2 class="section-title">What I Offer</h2>
        <p class="section-subtitle">End-to-end digital content solutions</p>

        <div class="services-grid">
            <div class="service-card reveal">
                <span class="service-icon">🎬</span>
                <div class="service-title">Video Production</div>
                <p class="service-desc">Professional video production for YouTube, Reels, TikTok and branded content. Script to final cut — handled with care.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">📱</span>
                <div class="service-title">Social Media Management</div>
                <p class="service-desc">Full management of all your social platforms. Strategy, scheduling, engagement and monthly analytics reports.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">🎨</span>
                <div class="service-title">Brand Identity Design</div>
                <p class="service-desc">Logos, color palettes, typography, style guides — everything you need to look premium and consistent everywhere.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">📊</span>
                <div class="service-title">Content Strategy</div>
                <p class="service-desc">Data-driven content calendars and strategy sessions to maximize reach and engagement on every platform.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">🤝</span>
                <div class="service-title">Brand Collaborations</div>
                <p class="service-desc">Sponsored content, product reviews, and brand partnerships. Let's create something that genuinely resonates.</p>
            </div>
            <div class="service-card reveal">
                <span class="service-icon">🎤</span>
                <div class="service-title">Speaking & Workshops</div>
                <p class="service-desc">Online and in-person workshops on content creation, personal branding, and the creator economy.</p>
            </div>
        </div>

        <div style="text-align:center; margin-top:60px;">
            <a href="/contact" class="btn-primary">Get in Touch →</a>
        </div>
    </section>
</div>